{
  "extends": "@repo/typescript-config/react.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "strictNullChecks": true,
    "baseUrl": ".",
    "rootDir": ".",
    "paths": {
      "@repo/ui/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}

